	volume = {34},
	issn = {1099-0852},
	shorttitle = {Psychological and {Emotional} {Harms} of {Online} {Child} {Sexual} {Exploitation} and {Abuse} in {Children} {Under} the {Age} of 18},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/car.70048},
	doi = {10.1002/car.70048},
	abstract = {Online child sexual exploitation and abuse (OCSEA) is a growing public health concern, with significant psychological and emotional impacts on victims. As digital communication evolves, the complexity and prevalence of OCSEA increase, highlighting the need for a comprehensive understanding of its effects on children. This systematic review examines the psychological and emotional harms experienced by victims under 18, with the goal of improving prevention and intervention strategies. This review also explores the relationship between specific forms of OCSEA and their psychological outcomes, informing future policies and practices. Following Cochrane guidelines and PRISMA standards, this review covers studies from 1989 onwards, including primary, secondary and mixed-methods research, as well as grey literature. Studies reporting psychological or emotional harm due to OCSEA victimisation are included. Data extraction and quality assessment were performed using standardised tools, and a narrative synthesis was employed to summarise the findings. This review enhances understanding of the psychological and emotional impacts of OCSEA, supporting the development of effective strategies for prevention and intervention.},
	language = {en},
	number = {4},
	urldate = {2026-02-18},
	journal = {Child Abuse Review},
	author = {Page, Sabrina and McFeeters, Ashleigh and Rani, Nurul Hasyimah Mat and Slater, Carleigh and Stevenson, James and Quayle, Ethel and Fry, Deborah},
	year = {2025},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/car.70048},
	keywords = {mental health, child sexual abuse material, online child sexual exploitation and abuse, psychological impact, public health, victimisation},
	pages = {e70048},
	annote = {e70048 CAR-012-25-ORA},
	file = {Full Text PDF:C\:\\Users\\lapto\\Zotero\\storage\\ZG94BTCS\\Page et al. - 2025 - Psychological and Emotional Harms of Online Child Sexual Exploitation and Abuse in Children Under th.pdf:application/pdf;Snapshot:C\:\\Users\\lapto\\Zotero\\storage\\4N6FA5LP\\car.html:text/html},
